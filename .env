# ASP.NET Core runtime
ASPNETCORE_ENVIRONMENT=Development

# Phase 1 runtime providers (still in-memory)
INFRASTRUCTURE_QUEUE_PROVIDER=InMemory
INFRASTRUCTURE_JOBSTORE_PROVIDER=InMemory

# External dependencies prepared for Phase 2
REDIS_CONNECTION_STRING=forgegpu-redis:6379
POSTGRES_CONNECTION_STRING=Host=forgegpu-postgres;Port=5432;Database=forgegpu;Username=forgegpu;Password=forgegpu

# Postgres container bootstrap
POSTGRES_DB=forgegpu
POSTGRES_USER=forgegpu
POSTGRES_PASSWORD=forgegpu
