{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Infrastructure": {
    "Runtime": {
      "QueueProvider": "Kafka",
      "JobStoreProvider": "Postgres"
    },
    "Redis": {
      "ConnectionString": "localhost:6379",
      "MachineProjectionKeyPrefix": "forgegpu:machines:live:"
    },
    "Kafka": {
      "BootstrapServers": "localhost:19092",
      "ConsumerGroupId": "forgegpu-coordinator",
      "ProducerClientId": "forgegpu-api",
      "Topics": {
        "W1_2": "forgegpu.jobs.w1_2",
        "W3_5": "forgegpu.jobs.w3_5",
        "W6_10": "forgegpu.jobs.w6_10",
        "W11_20": "forgegpu.jobs.w11_20",
        "W21_40": "forgegpu.jobs.w21_40",
        "W41Plus": "forgegpu.jobs.w41_plus"
      }
    },
    "Postgres": {
      "ConnectionString": "Host=localhost;Port=5432;Database=forgegpu;Username=forgegpu;Password=forgegpu"
    },
    "WorkerExecution": {
      "WorkerCount": 5,
      "MaxConcurrentJobsPerWorker": 1,
      "HeartbeatIntervalSeconds": 5,
      "HeartbeatTtlSeconds": 15,
      "SchedulerPolicy": "ResourceAwareBestFit",
      "Machines": [
        {
          "MachineId": "machine-01",
          "Name": "A100 Heavy Node",
          "TotalCapacityUnits": 15,
          "CpuScore": 42,
          "RamMb": 32768,
          "GpuVramMb": 12288,
          "MaxParallelWorkers": 2,
          "SupportedModels": [ "gpt-sim-a", "gpt-sim-mix" ]
        },
        {
          "MachineId": "machine-02",
          "Name": "L4 Throughput Node",
          "TotalCapacityUnits": 20,
          "CpuScore": 36,
          "RamMb": 49152,
          "GpuVramMb": 16384,
          "MaxParallelWorkers": 3,
          "SupportedModels": [ "gpt-sim-b", "gpt-sim-mix" ]
        },
        {
          "MachineId": "machine-03",
          "Name": "Balanced Multi-Model Node",
          "TotalCapacityUnits": 17,
          "CpuScore": 40,
          "RamMb": 65536,
          "GpuVramMb": 14336,
          "MaxParallelWorkers": 2,
          "SupportedModels": [ "gpt-sim-a", "gpt-sim-b", "gpt-sim-mix" ]
        },
        {
          "MachineId": "machine-04",
          "Name": "Edge Constraint Node",
          "TotalCapacityUnits": 5,
          "CpuScore": 16,
          "RamMb": 16384,
          "GpuVramMb": 4096,
          "MaxParallelWorkers": 1,
          "SupportedModels": [ "gpt-sim-a" ]
        },
        {
          "MachineId": "machine-05",
          "Name": "General Purpose Node",
          "TotalCapacityUnits": 12,
          "CpuScore": 28,
          "RamMb": 24576,
          "GpuVramMb": 8192,
          "MaxParallelWorkers": 2,
          "SupportedModels": [ "gpt-sim-b", "gpt-sim-mix" ]
        }
      ]
    },
    "Scheduling": {
      "DefaultModel": "gpt-sim-a",
      "DefaultRequiredMemoryMb": 4096,
      "DeferRetryDelayMs": 250,
      "ModelDefaults": [
        { "Model": "gpt-sim-a", "RequiredMemoryMb": 4096 },
        { "Model": "gpt-sim-b", "RequiredMemoryMb": 8192 },
        { "Model": "gpt-sim-mix", "RequiredMemoryMb": 6144 }
      ]
    },
    "Batching": {
      "Enabled": true,
      "BatchWindowMs": 50,
      "MaxBatchSize": 4,
      "MaxBatchMemoryMb": 16384
    },
    "Reliability": {
      "MaxRetries": 2,
      "ExecutionTimeoutMs": 2500,
      "RetryDelayMs": 500
    }
  },
  "AllowedHosts": "*"
}
