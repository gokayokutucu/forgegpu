{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Infrastructure": {
    "Runtime": {
      "QueueProvider": "Redis",
      "JobStoreProvider": "Postgres"
    },
    "Redis": {
      "ConnectionString": "localhost:6379",
      "QueueName": "forgegpu:inference:jobs:queue"
    },
    "Postgres": {
      "ConnectionString": "Host=localhost;Port=5432;Database=forgegpu;Username=forgegpu;Password=forgegpu"
    },
    "WorkerExecution": {
      "WorkerCount": 3,
      "MaxConcurrentJobsPerWorker": 1,
      "HeartbeatIntervalSeconds": 5,
      "SchedulerPolicy": "LeastLoadedGpuAware",
      "Workers": [
        {
          "WorkerId": "worker-01",
          "Name": "Inference Worker 1",
          "GpuId": "GPU-A100-01",
          "VramTotalMb": 12288,
          "MaxConcurrentJobs": 2,
          "SupportedModels": [ "gpt-sim-a", "gpt-sim-mix" ]
        },
        {
          "WorkerId": "worker-02",
          "Name": "Inference Worker 2",
          "GpuId": "GPU-L4-02",
          "VramTotalMb": 8192,
          "MaxConcurrentJobs": 2,
          "SupportedModels": [ "gpt-sim-b", "gpt-sim-mix" ]
        },
        {
          "WorkerId": "worker-03",
          "Name": "Inference Worker 3",
          "GpuId": "GPU-H100-03",
          "VramTotalMb": 16384,
          "MaxConcurrentJobs": 4,
          "SupportedModels": [ "gpt-sim-a", "gpt-sim-b", "gpt-sim-mix" ]
        }
      ]
    },
    "Scheduling": {
      "DefaultModel": "gpt-sim-a",
      "DefaultRequiredMemoryMb": 4096,
      "DeferRetryDelayMs": 250,
      "ModelDefaults": [
        { "Model": "gpt-sim-a", "RequiredMemoryMb": 4096 },
        { "Model": "gpt-sim-b", "RequiredMemoryMb": 8192 },
        { "Model": "gpt-sim-mix", "RequiredMemoryMb": 6144 }
      ]
    },
    "Batching": {
      "Enabled": true,
      "BatchWindowMs": 50,
      "MaxBatchSize": 4,
      "MaxBatchMemoryMb": 16384
    },
    "Reliability": {
      "MaxRetries": 2,
      "ExecutionTimeoutMs": 2500,
      "RetryDelayMs": 500
    }
  },
  "AllowedHosts": "*"
}
