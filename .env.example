# ASP.NET Core runtime
ASPNETCORE_ENVIRONMENT=Development

# Runtime providers
INFRASTRUCTURE_QUEUE_PROVIDER=Kafka
INFRASTRUCTURE_JOBSTORE_PROVIDER=Postgres

# Redis live projection
REDIS_CONNECTION_STRING=forgegpu-redis:6379
REDIS_MACHINE_PROJECTION_KEY_PREFIX=forgegpu:machines:live:

# Kafka ingress transport
KAFKA_BOOTSTRAP_SERVERS=forgegpu-kafka:9092
KAFKA_CONSUMER_GROUP_ID=forgegpu-coordinator
KAFKA_PRODUCER_CLIENT_ID=forgegpu-api
KAFKA_TOPIC_W1_2=forgegpu.jobs.w1_2
KAFKA_TOPIC_W3_5=forgegpu.jobs.w3_5
KAFKA_TOPIC_W6_10=forgegpu.jobs.w6_10
KAFKA_TOPIC_W11_20=forgegpu.jobs.w11_20
KAFKA_TOPIC_W21_40=forgegpu.jobs.w21_40
KAFKA_TOPIC_W41_PLUS=forgegpu.jobs.w41_plus

# Postgres durable store
POSTGRES_CONNECTION_STRING=Host=forgegpu-postgres;Port=5432;Database=forgegpu;Username=forgegpu;Password=forgegpu

# In-process worker pool
WORKER_COUNT=3
MAX_CONCURRENT_JOBS_PER_WORKER=1
WORKER_HEARTBEAT_INTERVAL_SECONDS=5
WORKER_HEARTBEAT_TTL_SECONDS=15
WORKER_SCHEDULER_POLICY=ResourceAwareBestFit

# Scheduling defaults
DEFAULT_MODEL=gpt-sim-a
DEFAULT_REQUIRED_MEMORY_MB=4096
DEFER_RETRY_DELAY_MS=250

# Dynamic batching
BATCHING_ENABLED=true
BATCH_WINDOW_MS=50
MAX_BATCH_SIZE=4
MAX_BATCH_MEMORY_MB=16384

# Reliability
MAX_RETRIES=2
EXECUTION_TIMEOUT_MS=2500
RETRY_DELAY_MS=500

# Postgres container bootstrap
POSTGRES_DB=forgegpu
POSTGRES_USER=forgegpu
POSTGRES_PASSWORD=forgegpu
